  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="BechtelAWP">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=DESKTOP-FKU7PGG;Initial Catalog=BechtelAWP;Trusted_Connection=True;TrustServerCertificate=True</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>883e0f14-69c0-4cc2-82f0-6f1cc0dba5ec</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>BechtelAWP</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT
    discipline,
    COUNT(*)                                           AS total_packages,
    SUM(planned_qty)                                   AS planned_qty,
    SUM(actual_qty)                                    AS actual_qty,
    ROUND(SUM(actual_qty)/SUM(planned_qty)*100, 1)     AS pct_complete,
    SUM(CASE WHEN status='Complete'    THEN 1 ELSE 0 END) AS complete,
    SUM(CASE WHEN status='In Progress' THEN 1 ELSE 0 END) AS in_progress,
    SUM(CASE WHEN status='Not Started' THEN 1 ELSE 0 END) AS not_started
FROM work_packages
GROUP BY discipline
ORDER BY pct_complete DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="discipline">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>discipline</DataField>
        </Field>
        <Field Name="total_packages">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>total_packages</DataField>
        </Field>
        <Field Name="planned_qty">
          <rd:TypeName>System.Double</rd:TypeName>
          <DataField>planned_qty</DataField>
        </Field>
        <Field Name="actual_qty">
          <rd:TypeName>System.Double</rd:TypeName>
          <DataField>actual_qty</DataField>
        </Field>
        <Field Name="pct_complete">
          <rd:TypeName>System.Double</rd:TypeName>
          <DataField>pct_complete</DataField>
        </Field>
        <Field Name="complete">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>complete</DataField>
        </Field>
        <Field Name="in_progress">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>in_progress</DataField>
        </Field>
        <Field Name="not_started">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>not_started</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
